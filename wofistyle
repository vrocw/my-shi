@import "../../.cache/wal/colors-waybar.css";

window {
  margin: 0px;
  border: 2px solid @color4;
  background-color: @background;
  border-radius: 20px;
}

#input {
  margin: 10px;
  border: none;
  color: @foreground;
  background-color: @color0;
  border-radius: 15px;
}

#inner-box {
  margin: 5px;
  border: none;
  background-color: transparent;
}

#outer-box {
  margin: 5px;
  border: none;
  background-color: transparent;
}

#scroll {
  margin: 0px;
  border: none;
}

#text {
  margin: 5px;
  border: none;
  color: @foreground;
} 

#entry {
  margin: 2px 10px;
  border-radius: 10px;
}

#entry.activatable #text {
  color: @foreground;
}

#entry > * {
  color: @foreground;
}

#entry:selected {
  background-color: @color2;
}

#entry:selected #text {
  font-weight: bold;
  color: @background;
}
