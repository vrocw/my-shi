@import "../../.cache/wal/colors-waybar.css";

* {
  font-family: 'JetBrainsMono Nerd Font';
  font-size: 12px;
  font-weight: bold;
  min-height: 0px;
}

window#waybar {
  background-color: transparent;
  transition-property: background-color;
  transition-duration: .5s;
}

window#waybar.empty #window {
  background: transparent;
  background-color: transparent;
  border: none;
  border-radius: 0;
  color: transparent;
  padding: 0;
  margin: 0;
}

#waybar.empty .modules-center {
  opacity: 0;
}

tooltip {
  opacity: 1;
}

#workspaces {
  border-radius: 2px;
  margin: 2px 3px;
}

#workspaces button {
  box-shadow: 0 1px 2px rgba(10, 10, 10, 0.8);
  padding: 0px 2px;
  margin: 0 3px 0 0;
  border-radius: 2px;
  background-color: alpha(@background, 0.85);
  color: @foreground;
  opacity: 1;
}

#workspaces button.active {
  background-color: alpha(@foreground, 1);
  border-radius: 2px;
  box-shadow: 0 1px 2px rgba(10, 10, 10, 0.8);
  color: @background;
  opacity: 1;
}

#workspaces button:hover {
  background-color: @foreground;
  color: @background;
}

#tray,
#window,
#mpris,
#cpu,
#clock,
#battery,
#network,
#memory,
#backlight,
#bluetooth,
#pulseaudio,
#power-profiles-daemon,
#custom-weather,
#custom-update,
#custom-idle-indicator,
#custom-notification-silencing-indicator,
#idle_inhibitor,
#custom-voxtype,
#custom-voxtype.recording,
#custom-voxtype.transcribing,
#custom-omarchy,
#custom-screenrecording-indicator,
#custom-updatespacman {
  min-width: 18px;
  margin: 2px 2px 2px 2px;
  padding: 0px 6px;
  border-radius: 2px;
  box-shadow: 0 1px 2px rgba(10, 10, 10, 0.8);
  background-color: alpha(@background, 0.85);
  color: @foreground;
  opacity: 1;
}

#power-profiles-daemon,
#power-profiles-daemon.performance,
#power-profiles-daemon.balanced,
#power-profiles-daemon.power-saver {
  font-size: 13.5px;
  padding-left: 3px;
}

#network {
  padding-left: 3px;
}

#memory {
  padding-right: 3px;
}

#pulseaudio.output {
  padding-right: 8px;
}

#clock:hover,
#tray:hover,
#custom-expand-icon:hover,
#cpu:hover,
#memory:hover,
#window:hover,
#mpris:hover,
#temperature:hover,
#battery:hover,
#power-profiles-daemon:hover,
#bluetooth:hover,
#backlight:hover,
#custom-omarchy:hover,
#custom-weather:hover,
#custom-update:hover,
#idle_inhibitor:hover,
#custom-screenrecording-indicator,
#custom-updatespacman:hover,
#network:hover,
#pulseaudio:hover {
  border-radius: 2px;
  opacity: 0.9;
  background-color: @foreground;
  color: @background;
}

#tray > .passive {
  -gtk-icon-effect: dim;
}

#tray > .needs-attention {
  -gtk-icon-effect: highlight;
  background-color: @transparent;
}

.hidden {
  opacity: 0;
}

tooltip {
  padding: 4px;
  background-color: alpha(@background, 1);
  opacity: 1;
  border: 1.5px solid alpha(@foreground, 0.8);
  border-radius: 4px;
  font-size: 12px;
}

tooltip label {
  color: @foreground;
  font-weight: normal;
}

#custom-voxtype {
  min-width: 12px;
  margin: 0 0 0 7.5px;
}

#custom-voxtype.recording {
  color: #a55555;
}

#custom-idle-indicator,
#custom-notification-silencing-indicator {
  min-width: 12px;
  margin-left: 3px;
  margin-right: 3px;
  font-size: 10px;
  padding-bottom: 0px;
}

#custom-idle-indicator.active {
  color: #a55555;
}

#custom-notification-silencing-indicator.active {
  color: #a55555;
}

#mpris {
  color: @foreground;
  animation: repeat;
  animation-name: blink;
  animation-duration: 3s;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
  animation-direction: alternate;
}

#custom-screenrecording-indicator {
  animation-timing-function: linear;
  animation-iteration-count: infinite;
  animation-direction: alternate;
  color: transparent;
}

#custom-screenrecording-indicator.active {
  color: #eb7087;
  background-color: alpha(@background, 0.85);
  animation-name: blink-recording;
  animation-duration: 0.5s;
}

@keyframes blink-recording {
  to {
    color: @foreground;
    background-color: alpha(@background, 0.85);
  }
}

@keyframes blink {
  to {
    color: #4a4a4a;
  }
}

#battery.warning {
  color: #c95d0f;
  background-color: alpha(@background, 0.85);
}

@keyframes blink2 {
  to {
    background-color: alpha(@background, 0.85);
    color: #f53c3c;
  }
}

#battery.critical:not(.charging) {
  background-color: alpha(@background, 0.85);
  color: #e6d8ba;
  animation-name: blink2;
  animation-duration: 0.5s;
  animation-timing-function: steps(12);
  animation-iteration-count: infinite;
  animation-direction: alternate;
}
