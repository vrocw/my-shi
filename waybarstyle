@import "../../.cache/wal/colors-waybar.css";

* {
  font-family: "JetBrainsMono Nerd Font";
  font-size: 13px;
  font-weight: bold;
}

window#waybar {
  background-color: transparent;
}

.modules-left,
.modules-center,
.modules-right {
  background-color: alpha(@background, 0.85);
  border: 1px solid @color4;
  border-radius: 20px;
  padding: 2px 14px;
  margin: 6px 8px;
}

#custom-launcher,
#clock,
#custom-weather,
#language,
#workspaces,
#bluetooth,
#pulseaudio,
#network,
#cpu,
#battery,
#tray {
  padding: 0 6px;
  color: @foreground;
}

#workspaces button {
  padding: 0 10px;
  color: @foreground;
  border-radius: 15px;
  margin: 2px;
  transition: all 0.2s ease;
  background-color: transparent;
  border: none;
  box-shadow: none;
}

#workspaces button.focused {
  background-color: @color2;
  color: @background;
}

#workspaces button:hover {
  background-color: @foreground;
  color: @background;
}

#battery.warning {
  color: #ff9e64;
}

#battery.critical {
  color: #f7768e;
  animation-name: blink;
  animation-duration: 0.5s;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
  animation-direction: alternate;
}

@keyframes blink {
  to {
    background-color: #f7768e;
    color: @background;
    border-radius: 10px;
  }
}
