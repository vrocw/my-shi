{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "mod": "dock",
  "margin-top": 4,
  "height": 30,
  "margin-left": 10,
  "margin-right": 10,
  "margin-bottom": 0,
  "modules-left": [
    "custom/omarchy",
    "clock",
    "custom/weather",
    "custom/notification-silencing-indicator",
    "custom/voxtype"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "tray",
    "bluetooth",
    "pulseaudio#output",
    "pulseaudio#input",
    "network",
    "memory",
    "cpu",
    "battery"
  ],
  "hyprland/workspaces": {
    "disable-scroll": true,
    "tooltip": false,
    "all-outputs": true,
    "format": "{name}"
  },
  "custom/omarchy": {
    "format": "<span font='omarchy'>\ue900</span>",
    "on-click": "omarchy-menu"
  },
  "custom/voxtype": {
    "exec": "omarchy-voxtype-status",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "idle": "",
      "recording": "󰍬",
      "transcribing": "󰔟"
    }
  },
  "custom/notification-silencing-indicator": {
    "exec": "$OMARCHY_PATH/default/waybar/indicators/notification-silencing.sh",
    "return-type": "json"
  },
  "cpu": {
    "interval": 2,
    "format": "{usage}% 󰍛"
  },
  "memory": {
    "interval": 2,
    "format": "{percentage}%  "
  },
  "clock": {
    "format": " {:%H:%M}"
  },
  "network": {
    "format-wifi": "󰤨",
    "format-ethernet": "󰈀",
    "format-disconnected": "󰖪"
  },
  "battery": {
    "format": "{capacity}% {icon}",
    "format-icons": ["󰁺", "󰁽", "󰁿", "󰂁", "󰁹"]
  },
  "bluetooth": {
    "format": "",
    "format-off": "󰂲"
  },
  "custom/weather": {
    "format": "{}°",
    "exec": "wttrbar --nerd --location yourlocation",
    "return-type": "json"
  },
  "pulseaudio#input": {
    "format-source": "",
    "format-source-muted": "",
    "format": "{format_source}"
  },
  "pulseaudio#output": {
    "format": "{icon}",
    "format-muted": "",
    "format-icons": {"default": [""]}
  },
  "tray": {
    "icon-size": 14,
    "spacing": 8
  }
}
